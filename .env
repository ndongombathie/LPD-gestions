# ===== CONFIGURATION API =====
# URL de base de l'API (backend)
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:6001

# ===== REVERB / WEBSOCKET (temps réel) =====
# À remplir pour que les commandes s'affichent sans actualisation (Laravel Reverb)
VITE_REVERB_APP_KEY=localkey
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# ===== APPLICATION =====
# Nom de l'application
VITE_APP_NAME=LPD Manager

# ===== ENVIRONMENT =====
# development, production, staging
VITE_ENV=development

# ===== LOGGING =====
# debug, info, warn, error
VITE_LOG_LEVEL=debug

# ===== MONITORING (OPTIONNEL) =====
# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# LogRocket Project ID
VITE_LOGROCKET_ID=

# ===== TIMEOUTS =====
# Timeout for API requests (in milliseconds)
VITE_API_TIMEOUT=10000

# ===== FEATURES (OPTIONNEL) =====
# Enable/disable features
VITE_ENABLE_QR_SCANNER=true
VITE_ENABLE_PDF_EXPORT=true
VITE_ENABLE_EXCEL_EXPORT=true
